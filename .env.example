# Copy to .env and `source` it. With nothing set, runs offline in stub mode.

# --- Gemma via Fireworks AI (Track 2 access path) --------------------------
# export LLM_BASE_URL="https://api.fireworks.ai/inference/v1"
# export LLM_API_KEY="fw-..."
# export LLM_MODEL="accounts/fireworks/models/gemma-4-26b-a4b-it"   # or the event's Gemma id

# --- Or Gemma on your AMD MI300X via vLLM ----------------------------------
# export LLM_BASE_URL="http://localhost:8000/v1"
# export LLM_API_KEY="EMPTY"
# export LLM_MODEL="google/gemma-3-27b-it"

# --- FREE local dev/eval: real Gemma via Ollama (zero cost) ----------------
# ollama pull gemma3:4b           # Gemma 3, multimodal (vision) — full pipeline
# export LLM_BASE_URL="http://localhost:11434/v1"
# export LLM_API_KEY="ollama"
# export LLM_MODEL="gemma3:4b"    # gemma2:2b works for styling only (no vision)

# --- Optional --------------------------------------------------------------
# export VC_N_FRAMES="6"       # frames sampled per clip
